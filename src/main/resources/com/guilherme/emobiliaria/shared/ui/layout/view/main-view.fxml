<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import java.net.URL?>
<BorderPane
    xmlns:fx="http://javafx.com/fxml"
    fx:controller="com.guilherme.emobiliaria.shared.ui.layout.MainController"
    styleClass="main-root">

    <stylesheets>
        <URL value="@main-view.css"/>
        <URL value="@/com/guilherme/emobiliaria/shared/ui/style/buttons.css"/>
        <URL value="@/com/guilherme/emobiliaria/shared/ui/style/forms.css"/>
    </stylesheets>

    <top>
        <HBox fx:id="navBar" styleClass="nav-bar">
            <Button fx:id="backButton"/>
            <Button fx:id="forwardButton"/>
        </HBox>
    </top>

    <left>
        <VBox fx:id="sidebarContainer"/>
    </left>

    <center>
        <StackPane fx:id="contentPane" styleClass="content-area"/>
    </center>

</BorderPane>
