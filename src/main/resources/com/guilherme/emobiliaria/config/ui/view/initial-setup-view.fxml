<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import java.net.URL?>
<StackPane
    xmlns:fx="http://javafx.com/fxml"
    fx:controller="com.guilherme.emobiliaria.config.ui.controller.InitialSetupController"
    styleClass="setup-bg"
    prefWidth="1440"
    prefHeight="900">

    <stylesheets>
        <URL value="@initial-setup.css"/>
        <URL value="@/com/guilherme/emobiliaria/shared/ui/style/forms.css"/>
        <URL value="@/com/guilherme/emobiliaria/shared/ui/style/buttons.css"/>
        <URL value="@/com/guilherme/emobiliaria/shared/ui/style/stepper.css"/>
    </stylesheets>

    <VBox styleClass="setup-card" maxWidth="720" StackPane.alignment="CENTER">

        <!-- HEADER -->
        <VBox styleClass="setup-header">
            <Label fx:id="stepTitleLabel" styleClass="setup-title"/>
            <Label fx:id="stepSubtitleLabel" styleClass="setup-subtitle"/>
        </VBox>

        <Separator styleClass="setup-divider"/>

        <!-- STEPPER -->
        <HBox fx:id="stepperContainer" styleClass="setup-stepper"/>

        <Separator styleClass="setup-divider"/>

        <!-- CONTENT (programmatically swapped per step) -->
        <StackPane fx:id="contentPane" styleClass="setup-content" VBox.vgrow="ALWAYS"/>

        <!-- FOOTER -->
        <HBox styleClass="setup-footer">
            <Button fx:id="backButton" styleClass="btn-secondary"/>
            <Button fx:id="nextButton" styleClass="btn-primary"/>
        </HBox>

    </VBox>

</StackPane>
