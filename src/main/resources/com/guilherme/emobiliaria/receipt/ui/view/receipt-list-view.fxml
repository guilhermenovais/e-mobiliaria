<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import java.net.URL?>
<VBox
    xmlns:fx="http://javafx.com/fxml"
    styleClass="receipt-list-root">

    <stylesheets>
        <URL value="@receipt-list-view.css"/>
        <URL value="@/com/guilherme/emobiliaria/shared/ui/style/forms.css"/>
        <URL value="@/com/guilherme/emobiliaria/shared/ui/style/buttons.css"/>
    </stylesheets>

    <!-- HEADER -->
    <HBox styleClass="list-view-header-row">
        <VBox styleClass="list-view-header-texts">
            <Label fx:id="titleLabel" styleClass="list-view-title"/>
            <Label fx:id="subtitleLabel" styleClass="list-view-subtitle"/>
        </VBox>
        <Region HBox.hgrow="ALWAYS"/>
        <Button fx:id="newButton" styleClass="btn-primary"/>
    </HBox>

    <!-- CONTRACT FILTER -->
    <HBox styleClass="receipt-list-filter-row">
        <VBox styleClass="receipt-list-filter-field">
            <Label fx:id="contractFilterLabel" styleClass="form-label"/>
            <HBox spacing="8">
                <ComboBox fx:id="contractComboBox" styleClass="form-combo" maxWidth="480" HBox.hgrow="ALWAYS"/>
                <Button fx:id="clearFilterButton" styleClass="btn-secondary"/>
            </HBox>
        </VBox>
    </HBox>

    <!-- TABLE -->
    <StackPane styleClass="list-table-container" VBox.vgrow="ALWAYS">
        <TableView fx:id="tableView" styleClass="list-table-view"/>
        <Label fx:id="emptyLabel" styleClass="list-empty-label" StackPane.alignment="CENTER"/>
    </StackPane>

    <!-- PAGINATION -->
    <HBox styleClass="list-view-pagination">
        <Label fx:id="pageLabel"/>
        <Region HBox.hgrow="ALWAYS"/>
        <Button fx:id="prevButton" styleClass="btn-secondary"/>
        <Button fx:id="nextButton" styleClass="btn-secondary"/>
    </HBox>

</VBox>
