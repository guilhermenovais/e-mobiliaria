<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import java.net.URL?>
<ScrollPane
    xmlns:fx="http://javafx.com/fxml"
    fitToWidth="true">

    <stylesheets>
        <URL value="@property-form-view.css"/>
        <URL value="@/com/guilherme/emobiliaria/shared/ui/style/forms.css"/>
        <URL value="@/com/guilherme/emobiliaria/shared/ui/style/buttons.css"/>
    </stylesheets>

    <VBox styleClass="form-view-root">

        <!-- HEADER -->
        <VBox styleClass="form-view-header">
            <Label fx:id="titleLabel" styleClass="form-view-title"/>
            <Label fx:id="subtitleLabel" styleClass="form-view-subtitle"/>
        </VBox>

        <Separator/>

        <!-- PROPERTY DATA SECTION -->
        <Label fx:id="propertySectionLabel" styleClass="form-section-label"/>
        <StackPane fx:id="propertyFormContainer"/>

        <Separator/>

        <!-- ADDRESS SECTION -->
        <Label fx:id="addressSectionLabel" styleClass="form-section-label"/>
        <StackPane fx:id="addressFormContainer"/>

        <!-- FOOTER -->
        <HBox styleClass="form-view-footer">
            <Button fx:id="cancelButton" styleClass="btn-secondary"/>
            <Button fx:id="saveButton" styleClass="btn-primary"/>
        </HBox>

    </VBox>

</ScrollPane>
